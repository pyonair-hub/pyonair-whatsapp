# ===========================================
# PYONAIR WHATSAPP - Environment Configuration
# ===========================================
# Copy this to .env and fill in your values
# Documentation: https://pyonair.com/docs/whatsapp

# ===========================================
# REQUIRED: Set these before starting
# ===========================================

# Generate a strong API key: openssl rand -hex 32
PYONAIR_API_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Your public URL (e.g., https://wa.yourclient.pyonair.com)
PYONAIR_WHATSAPP_URL=http://localhost:8080

# Database password (generate: openssl rand -base64 24)
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
POSTGRES_USER=pyonair
POSTGRES_DB=pyonair_whatsapp

# ===========================================
# WEBHOOK: Pyonair Support (Chatwoot) Integration
# ===========================================

# Chatwoot webhook URL for incoming messages
PYONAIR_WEBHOOK_URL=http://chatwoot:3000/webhooks/whatsapp

# Optional: Error notification webhook (Slack/Discord/custom)
PYONAIR_ERROR_WEBHOOK_URL=

# ===========================================
# OPTIONAL: Additional Integrations
# ===========================================

# N8N automation webhook (if using Pyonair Automations)
# N8N_WEBHOOK_URL=http://n8n:5678/webhook/whatsapp

# OpenAI for AI-powered auto-replies
# OPENAI_API_KEY=sk-...

# S3/MinIO for media storage (recommended for production)
# S3_ENABLED=true
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=
# S3_BUCKET=pyonair-whatsapp-media
# S3_REGION=us-east-1
